16986 silly resolved   { name: 'CSSselect',
16986 silly resolved     version: '0.4.1',
16986 silly resolved     description: 'a CSS selector compiler/engine',
16986 silly resolved     author: { name: 'Felix Boehm', email: 'me@feedic.com' },
16986 silly resolved     keywords: [ 'css', 'selector' ],
16986 silly resolved     repository: { type: 'git', url: 'git://github.com/fb55/CSSselect.git' },
16986 silly resolved     dependencies: { CSSwhat: '0.4', domutils: '1.4' },
16986 silly resolved     devDependencies:
