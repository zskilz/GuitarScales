13307 silly resolved     version: '2.5.0',
13307 silly resolved     author: { name: 'Isaac Z. Schlueter', email: 'i@izs.me' },
13307 silly resolved     scripts: { test: 'tap test --gc' },
13307 silly resolved     main: 'lib/lru-cache.js',
