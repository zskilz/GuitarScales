17444 silly resolved     readme: 'Node.JS module “Deep Extend”\r\n============================\r\n\r\nRecursive object extending.\r\n\r\nInstall\r\n-----\r\n\r\n    npm install deep-extend\r\n\r\nUsage\r\n-----\r\n\r\n    var deepExtend = require(\'deep-extend\');\r\n    var obj1 = {\r\n        a: 1,\r\n        b: 2,\r\n        d: {\r\n            a: 1,\r\n            b: [],\r\n            c: { test1: 123, test2: 321 }\r\n        },\r\n        f: 5,\r\n        g: 123\r\n    };\r\n    var obj2 = {\r\n        b: 3,\r\n        c: 5,\r\n        d: {\r\n            b: { first: \'one\', second: \'two\' },\r\n            c: { test2: 222 }\r\n        },\r\n        e: { one: 1, two: 2 },\r\n        f: [],\r\n        g: (void 0)\r\n    };\r\n\r\n    deepExtend(obj1, obj2);\r\n\r\n    console.log(obj1);\r\n    /*\r\n        { a: 1,\r\n          b: 3,\r\n          d:\r\n           { a: 1,\r\n             b: { first: \'one\', second: \'two\' },\r\n             c: { test1: 123, test2: 222 } },\r\n          f: [],\r\n          c: 5,\r\n          e: { one: 1, two: 2 },\r\n          g: undefined }\r\n    */\r\n',
